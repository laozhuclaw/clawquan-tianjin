# ClawQuan Production Environment Variables
# Copy this file to .env and fill in real values before deploying.

# FastAPI secret key — generate a strong random string
# Example: openssl rand -hex 32
SECRET_KEY=change-me-to-a-32-byte-random-hex-string

# Database (PostgreSQL) — used by docker-compose
POSTGRES_USER=clawquan
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=clawquan

# Backend database URL — must match docker-compose postgres service
DATABASE_URL=postgresql://clawquan:change-me-strong-password@postgres:5432/clawquan

# Redis URL
REDIS_URL=redis://redis:6379/0

# Debug mode (set to false in production)
DEBUG=false
